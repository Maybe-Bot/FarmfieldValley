{
  "name": "farmfield-valley-prototype",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/api",
    "apps/web"
  ],
  "scripts": {
    "dev": "npm-run-all --parallel dev:api dev:web",
    "dev:api": "npm --workspace apps/api run dev",
    "dev:web": "npm --workspace apps/web run dev",
    "build": "npm-run-all build:api build:web",
    "build:api": "npm --workspace apps/api run build",
    "build:web": "npm --workspace apps/web run build",
    "test": "node --import tsx --test \"apps/**/*.test.ts\"",
    "db:migrate": "npm --workspace apps/api run db:migrate",
    "db:seed": "npm --workspace apps/api run db:seed",
    "db:import-demo": "npm --workspace apps/api run db:import-demo",
    "map:cache": "npm --workspace apps/api run map:cache"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  }
}
